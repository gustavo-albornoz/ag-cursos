generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ALUMNO
  PROFESOR
  ADMIN
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  role      Role       @default(ALUMNO)
  purchases Purchase[]
}

model Course {
  id          String     @id @default(uuid())
  title       String
  description String
  price       Float
  imageUrl    String?
  modules     Module[]
  purchases   Purchase[]
}

model Module {
  id       String @id @default(uuid())
  title    String
  videoUrl String
  courseId String
  course   Course @relation(fields: [courseId], references: [id])
}

model Purchase {
  id       String @id @default(uuid())
  userId   String
  courseId String
  status   String @default("PENDING")
  user     User   @relation(fields: [userId], references: [id])
  course   Course @relation(fields: [courseId], references: [id])
}
